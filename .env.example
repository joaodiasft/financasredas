# PostgreSQL (ex.: Prisma Postgres). Substitua por sua URL com sslmode=require se necessário.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Assinatura dos cookies de sessão (use um valor longo e aleatório em produção)
JWT_SECRET="troque_por_um_segredo_longo_em_producao"
